{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "forge",
  "version": "0.1.0",
  "identifier": "com.forge.terminal",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Forge Terminal",
        "width": 1024,
        "height": 768,
        "minWidth": 640,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVBMDYyNTI3NzA1RTUwODUKUldTRlVGNXdKeVVHNnQ0c3ZwOTIyZHZTcnoxVmt6eEJUeGVFV1dIRlRqWnduRisrRldMalNZM1kK",
      "endpoints": [
        "https://github.com/GGos3/forge/releases/download/latest/{{current_version}}.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
